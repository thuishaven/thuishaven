---
import Base from "../layouts/Base.astro";
---

<Base
  title="Not found — Thuishaven"
  description="This page doesn't exist."
>
  <section class="py-24 text-center">
    <h1 class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white">
      404 — nothing docked here
    </h1>
    <p class="mt-4 text-slate-600 dark:text-slate-400">
      This page doesn't exist. The patterns do, though.
    </p>
    <a
      href="/patterns/"
      class="mt-8 inline-block rounded-lg bg-harbor-600 px-5 py-2.5 font-medium text-white hover:bg-harbor-700 dark:bg-harbor-500 dark:text-slate-950 dark:hover:bg-harbor-400"
      >Browse patterns</a
    >
  </section>
</Base>
